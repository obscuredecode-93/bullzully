# MongoDB Atlas connection string
# Get this from Atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bullzully?retryWrites=true&w=majority

# TCP port the Express server listens on
PORT=3001

# Allowed frontend origin for CORS (set to your Vercel deployment URL in production)
# Leave unset to allow all origins (fine for development)
CLIENT_URL=your_vercel_frontend_url
