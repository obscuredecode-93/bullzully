# API server base URL (no trailing slash, no /api suffix)
#
# Local development: leave this unset — Vite's dev proxy forwards /api → localhost:3001
# automatically (configured in vite.config.js).
#
# Production (cross-origin deploy — client on Vercel, server on Railway/Render):
# Set this in your Vercel project's Environment Variables dashboard.
# Example: VITE_API_URL=https://bullzully-server.up.railway.app
VITE_API_URL=
